<?xml version="1.0" encoding="utf-8"?>
<network-security-config>
    <!--
        The Uninorte streaming server does not send the intermediate certificate
        "Thawte TLS RSA CA G1" during the TLS handshake. Android fails to build
        the trust chain without it, so we bundle it here.

        uninorte_ca.crt = Thawte TLS RSA CA G1 (intermediate)
        Its issuer (DigiCert Global Root G2) is already in Android's system store.

        To refresh (cert expires 2031-11-01):
          curl -s http://cacerts.thawte.com/ThawteTLSRSACAG1.crt \
            | openssl x509 -inform DER -outform PEM \
            > android/app/src/main/res/raw/uninorte_ca.crt
    -->
    <domain-config cleartextTrafficPermitted="false">
        <domain includeSubdomains="true">uninorte.edu.co</domain>
        <trust-anchors>
            <certificates src="system"/>
            <certificates src="@raw/uninorte_ca"/>
        </trust-anchors>
    </domain-config>

    <base-config cleartextTrafficPermitted="false">
        <trust-anchors>
            <certificates src="system"/>
        </trust-anchors>
    </base-config>
</network-security-config>

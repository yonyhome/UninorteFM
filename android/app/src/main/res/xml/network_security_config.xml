<?xml version="1.0" encoding="utf-8"?>
<network-security-config>
    <!-- Allow HTTP only for the radio stream server whose TLS cert is not
         trusted by Android's default CA store. All other traffic stays HTTPS. -->
    <domain-config cleartextTrafficPermitted="true">
        <domain includeSubdomains="true">cactus2.uninorte.edu.co</domain>
    </domain-config>
    <base-config cleartextTrafficPermitted="false">
        <trust-anchors>
            <certificates src="system"/>
        </trust-anchors>
    </base-config>
</network-security-config>
